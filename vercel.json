{
  "redirects": [
    {
      "source": "/lp-demo",
      "destination": "/lab/lp-dashboard/",
      "permanent": false
    },
    {
      "source": "/lp-demo/",
      "destination": "/lab/lp-dashboard/",
      "permanent": false
    },
    {
      "source": "/lp-demo/:path*",
      "destination": "/lab/lp-dashboard/:path*",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/log-live-sales",
      "schedule": "0 12 * * *"
    }
  ],
  "ignoreCommand": "git log -1 --pretty=%B | grep -qE '^(chore|report): (log|update) live sales|^chore: bump deploy|^report: daily sales' && exit 0 || exit 1"
}
